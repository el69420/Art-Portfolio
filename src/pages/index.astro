---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const base = '/Art-Portfolio';
const allPages = await getCollection('pages');
const pages = allPages.sort((a, b) => a.id.localeCompare(b.id));
---
<Base title="Sketchbook">
  <div class="scene">
    <div class="book-wrapper" id="bookWrapper">
    <div class="book" id="book">

      <!-- Left page area (verso) — revealed when cover opens -->
      <div class="book-left" id="bookLeft">
        <div class="book-left-paper"></div>
      </div>

      <!-- Spine -->
      <div class="spine"></div>

      <!-- Back cover — fixed behind all pages, revealed when last page is turned -->
      <div class="back-cover">
        <div class="back-cover-inner"></div>
      </div>

      <!-- Cover — full width when closed, flips left when opened -->
      <div class="cover" id="cover">
        <div class="cover-front">
          <div class="elastic-h"></div>
          <div class="elastic-v"></div>
          <div class="cover-title">
            <span class="cover-label">Sketchbook</span>
            <span class="cover-sub">Vol. I</span>
          </div>
        </div>
        <div class="cover-back"></div>
      </div>

      <!-- Contents page (leaf 0) — right half, flips from spine -->
      <div class="page-leaf" data-index="0" id="page-0" style={`z-index:${pages.length + 1}`}>
        <div class="page-recto">
          <h2 class="contents-page-heading">Contents</h2>
          <ol class="contents-page-list">
            {pages.map((page, i) => (
              <li class="contents-page-item">
                <button class="contents-jump" data-target={i + 1}>
                  <span class="contents-num">{String(i + 1).padStart(3, '0')}</span>
                  <span class="contents-dots"></span>
                  <span class="contents-title">{page.data.title}</span>
                </button>
              </li>
            ))}
          </ol>
          <span class="page-number">000</span>
        </div>
        <div class="page-verso"></div>
      </div>

      <!-- Artwork pages (leaves 1…n) -->
      {pages.map((page, i) => {
        const rot = ((i * 37 + 7) % 11) - 5;
        const num = String(i + 1).padStart(3, '0');
        const leafIndex = i + 1;
        return (
          <div class="page-leaf" data-index={leafIndex} id={`page-${leafIndex}`} style={`z-index:${pages.length + 1 - leafIndex}`}>
            <div class="page-recto">
              {page.data.image && (
                <div class="page-image-wrap" style={`--rot:${rot}deg`}>
                  <div class="page-image-mount">
                    <img src={`${base}${page.data.image}`} alt={page.data.title} class="page-image" />
                  </div>
                </div>
              )}
              <p class="page-caption">{page.data.caption}</p>
              <div class="page-meta">
                {[page.data.date, page.data.location, page.data.materials]
                  .filter(Boolean)
                  .join(' · ')}
              </div>
              {page.data.finished === false && <span class="unfinished-label">unfinished</span>}
              <span class="page-number">{num}</span>
            </div>
            <div class="page-verso"></div>
          </div>
        );
      })}

      <!-- Edge click zones -->
      <div class="edge-zone edge-zone--right" id="edgeRight"></div>
      <div class="edge-zone edge-zone--left" id="edgeLeft"></div>
    </div>
    </div>

    <div class="page-counter" id="pageCounter"></div>
  </div>

  <script>
    const cover = document.getElementById('cover')!;
    const bookWrapper = document.getElementById('bookWrapper')!;
    const bookLeft = document.getElementById('bookLeft')!;
    const edgeRight = document.getElementById('edgeRight')!;
    const edgeLeft = document.getElementById('edgeLeft')!;
    const pageCounter = document.getElementById('pageCounter')!;
    const pageLeaves = Array.from(document.querySelectorAll<HTMLElement>('.page-leaf'));
    const contentsJumps = Array.from(document.querySelectorAll<HTMLElement>('.contents-jump'));

    let current = -1;
    const total = pageLeaves.length;

    function updateUI() {
      bookWrapper.classList.toggle('open', current >= 0);
      bookLeft.classList.toggle('visible', current >= 0);
      edgeLeft.classList.toggle('visible', current >= 0);
      edgeRight.classList.toggle('visible', current < total - 1);
      pageCounter.textContent = current < 0 ? '' : current === 0 ? 'Contents' : `${current} / ${total - 1}`;
    }

    function applyState(index: number) {
      cover.classList.toggle('open', index >= 0);
      pageLeaves.forEach((leaf, i) => {
        if (i <= index) leaf.classList.add('turned');
        else leaf.classList.remove('turned');
      });
      current = index;
      updateUI();
    }

    function animateTo(target: number) {
      if (target === current) return;
      const step = target > current ? 1 : -1;
      const FLIP_DELAY = 140;
      let i = current;

      function flipNext() {
        i += step;
        applyState(i);
        if (i !== target) setTimeout(flipNext, FLIP_DELAY);
      }

      if (target >= 0 && current < 0) {
        applyState(0);
        setTimeout(() => { i = 0; if (target !== 0) setTimeout(flipNext, FLIP_DELAY); }, 500);
      } else {
        flipNext();
      }
    }

    function next() { if (current < total - 1) animateTo(current + 1); }
    function prev() {
      if (current > 0) animateTo(current - 1);
      else if (current === 0) applyState(-1);
    }

    edgeRight.addEventListener('click', next);
    edgeLeft.addEventListener('click', prev);

    contentsJumps.forEach(btn => {
      btn.addEventListener('click', () => animateTo(parseInt(btn.dataset.target ?? '1')));
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight' || e.key === 'ArrowDown') next();
      else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') prev();
    });

    let touchStartX = 0;
    document.addEventListener('touchstart', (e) => { touchStartX = e.touches[0].clientX; }, { passive: true });
    document.addEventListener('touchend', (e) => {
      const dx = e.changedTouches[0].clientX - touchStartX;
      if (Math.abs(dx) > 50) dx < 0 ? next() : prev();
    }, { passive: true });

    updateUI();
  </script>
</Base>
