---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const base = '/Art-Portfolio';
const allPages = await getCollection('pages');
const pages = allPages.sort((a, b) => a.id.localeCompare(b.id));
---
<Base title="Sketchbook">
  <div class="scene">
    <div class="book" id="book">

      <!-- Cover -->
      <div class="cover" id="cover">
        <div class="cover-front">
          <div class="elastic-h"></div>
          <div class="elastic-v"></div>
          <div class="cover-title">
            <span class="cover-label">Sketchbook</span>
            <span class="cover-sub">Vol. I</span>
          </div>
          <button class="cover-open-btn" id="coverOpenBtn" aria-label="Open sketchbook">Open</button>
        </div>
      </div>

      <!-- Contents page (leaf 0) -->
      <div class="page-leaf" data-index="0" id="page-0">
        <div class="page-inner">
          <div class="page-recto">
            <div class="ruled-lines"></div>
            <h2 class="contents-page-heading">Contents</h2>
            <ol class="contents-page-list">
              {pages.map((page, i) => (
                <li class="contents-page-item">
                  <button class="contents-jump" data-target={i + 1}>
                    <span class="contents-num">{String(i + 1).padStart(3, '0')}</span>
                    <span class="contents-dots"></span>
                    <span class="contents-title">{page.data.title}</span>
                  </button>
                </li>
              ))}
            </ol>
            <span class="page-number">000</span>
          </div>
        </div>
      </div>

      <!-- Artwork pages (leaves 1…n) -->
      {pages.map((page, i) => {
        const rot = ((i * 37 + 7) % 11) - 5;
        const num = String(i + 1).padStart(3, '0');
        const leafIndex = i + 1;
        return (
          <div class="page-leaf" data-index={leafIndex} id={`page-${leafIndex}`}>
            <div class="page-inner">
              <div class="page-recto">
                <div class="ruled-lines"></div>
                {page.data.image && (
                  <div class="page-image-wrap" style={`--rot:${rot}deg`}>
                    <img src={`${base}${page.data.image}`} alt={page.data.title} class="page-image" />
                  </div>
                )}
                <p class="page-caption">{page.data.caption}</p>
                <div class="page-meta">
                  {[page.data.date, page.data.location, page.data.materials]
                    .filter(Boolean)
                    .join(' · ')}
                </div>
                {page.data.finished === false && <span class="unfinished-label">unfinished</span>}
                <span class="page-number">{num}</span>
              </div>
            </div>
          </div>
        );
      })}

      <!-- Page edge stack -->
      <div class="page-edges" id="pageEdges">
        {[...Array(pages.length + 1)].map((_, i) => (
          <div class="page-edge-slice" data-target={i}></div>
        ))}
      </div>
    </div>

    <!-- Nav -->
    <div class="nav" id="nav" hidden>
      <button class="nav-btn" id="prevBtn" aria-label="Previous page">&#8592;</button>
      <span class="nav-info" id="navInfo"></span>
      <button class="nav-btn" id="nextBtn" aria-label="Next page">&#8594;</button>
    </div>
  </div>

  <script>
    const cover = document.getElementById('cover')!;
    const coverOpenBtn = document.getElementById('coverOpenBtn')!;
    const nav = document.getElementById('nav')!;
    const navInfo = document.getElementById('navInfo')!;
    const prevBtn = document.getElementById('prevBtn')!;
    const nextBtn = document.getElementById('nextBtn')!;
    const pageLeaves = Array.from(document.querySelectorAll<HTMLElement>('.page-leaf'));
    const edgeSlices = Array.from(document.querySelectorAll<HTMLElement>('.page-edge-slice'));
    const contentsJumps = Array.from(document.querySelectorAll<HTMLElement>('.contents-jump'));

    // leaf 0 = contents, leaves 1..n = artwork pages
    // current: -1 = cover closed, 0 = contents visible, 1..n = artwork page visible
    let current = -1;
    const total = pageLeaves.length; // includes contents leaf

    function updateNav() {
      if (current < 0) { nav.hidden = true; return; }
      nav.hidden = false;
      // Display: contents = "Contents", others = "1 / 4" etc
      navInfo.textContent = current === 0 ? 'Contents' : `${current} / ${total - 1}`;
      (prevBtn as HTMLButtonElement).disabled = current <= 0;
      (nextBtn as HTMLButtonElement).disabled = current >= total - 1;
    }

    function applyState(index: number) {
      if (index >= 0) cover.classList.add('open');
      else cover.classList.remove('open');

      pageLeaves.forEach((leaf, i) => {
        // leaves after current index stack on top — flip them away to reveal current
        if (i > index) leaf.classList.add('turned');
        else leaf.classList.remove('turned');
      });

      current = index;
      updateNav();
    }

    // Animated sequential flip from current to target
    function animateTo(target: number) {
      if (target === current) return;
      const step = target > current ? 1 : -1;
      const FLIP_DELAY = 120; // ms between page flips

      let i = current;
      function flipNext() {
        i += step;
        applyState(i);
        if (i !== target) setTimeout(flipNext, FLIP_DELAY);
      }

      // Open cover first if needed, then start flipping
      if (target >= 0 && current < 0) {
        applyState(0);
        setTimeout(() => {
          i = 0;
          if (target !== 0) setTimeout(flipNext, FLIP_DELAY);
        }, 460);
      } else {
        flipNext();
      }
    }

    function next() { if (current < total - 1) animateTo(current + 1); }
    function prev() {
      if (current > 0) animateTo(current - 1);
      else if (current === 0) applyState(-1);
    }

    coverOpenBtn.addEventListener('click', () => animateTo(0));
    nextBtn.addEventListener('click', next);
    prevBtn.addEventListener('click', prev);

    edgeSlices.forEach((slice) => {
      slice.addEventListener('click', () => {
        const target = parseInt(slice.dataset.target ?? '0');
        animateTo(target);
      });
    });

    contentsJumps.forEach((btn) => {
      btn.addEventListener('click', () => {
        const target = parseInt(btn.dataset.target ?? '1');
        animateTo(target);
      });
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight' || e.key === 'ArrowDown') next();
      else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') prev();
    });

    let touchStartX = 0;
    document.addEventListener('touchstart', (e) => { touchStartX = e.touches[0].clientX; }, { passive: true });
    document.addEventListener('touchend', (e) => {
      const dx = e.changedTouches[0].clientX - touchStartX;
      if (Math.abs(dx) > 50) dx < 0 ? next() : prev();
    }, { passive: true });

    updateNav();
  </script>
</Base>
